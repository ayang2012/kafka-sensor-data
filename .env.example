# MQTT / IoT Gateway
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TOPIC_PREFIX=sensors

# Simulator
MIN_INTERVAL_MS=30
MAX_INTERVAL_MS=300
PROFILES_PATH=sensor_profiles.pkl

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=sensor-readings
KAFKA_CONSUMER_GROUP=sensor-consumer-group

# S3 / Bronze layer
S3_BUCKET=sensor-readings-bronze
S3_PREFIX=sensor-readings
FLUSH_INTERVAL_SECONDS=60
FLUSH_BATCH_SIZE=500

# For LocalStack (local dev). Remove for real AWS.
S3_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
